#!/usr/bin/env bash
set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|hpp)$' || true)

# clang-format
if [[ -n "$STAGED" ]]; then
    echo "clang-format..."
    while IFS= read -r file; do
        clang-format --dry-run --Werror "$file"
    done <<< "$STAGED"
fi

# clang-tidy
STAGED_CPP=$(echo "$STAGED" | grep -E '\.cpp$' || true)
if [[ -n "$STAGED_CPP" ]]; then
    echo "clang-tidy..."
    while IFS= read -r file; do
        clang-tidy -p build --quiet "$file"
    done <<< "$STAGED_CPP"
fi

# nolint explanation check
if [[ -n "$STAGED" ]]; then
    echo "nolint explanation check..."
    violations=$(echo "$STAGED" | xargs grep -nH 'NOLINT' | grep -v 'NOLINTEND' | grep -vE 'NOLINT[A-Z]*\([^)]+\)\s*-' || true)
    if [[ -n "$violations" ]]; then
        echo "NOLINT comments must have a check name and explanation: NOLINT(check-name) - reason"
        echo "$violations"
        exit 1
    fi
fi

# compile
echo "building..."
cmake --build build

# test
echo "testing..."
./build/tests -q

# cross-compile (ce c/c++ toolchain)
if command -v ez80-clang &>/dev/null; then
    echo "cross-compiling (CE)..."
    make -f makefile
else
    echo "warning: ez80-clang not on PATH. skipping!"
fi
